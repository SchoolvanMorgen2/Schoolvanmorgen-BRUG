# School van morgen — omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in
# Voeg .env toe aan je .gitignore — nooit committen

# Mistral API (https://console.mistral.ai)
MISTRAL_API_KEY=jouw_mistral_key_hier

# Parnassys GKV (na goedkeuring koppelpartner intake)
PARNASSYS_API_URL=https://api.parnassys.nl/gkv
PARNASSYS_TOKEN=jouw_parnassys_token_hier

# Database (PostgreSQL op Hetzner of Scaleway)
DATABASE_URL=postgresql://gebruiker:wachtwoord@localhost/schoolvanmorgen
